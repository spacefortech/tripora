<!DOCTYPE html>
<html lang="{% block locale %}de{% endblock %}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Tripora - City Guides und Wochenendrouten{% endblock %}</title>
    <meta name="description" content="{% block description %}Entdecke kuratierte Orte, Routen und Reiseideen für inspirierende Städtetrips.{% endblock %}">
    {% block stylesheets %}
        <link rel="preload" href="/assets/header-sea-hero.png" as="image">
        <link rel="stylesheet" href="/assets/app.css">
    {% endblock %}
</head>
<body>
    {% block body %}{% endblock %}

    {% block javascripts %}
        <script src="/assets/app.js" defer></script>
    {% endblock %}
</body>
</html>
