{% extends 'base.html.twig' %}

{% block title %}Tripora - Cool Places in Duisburg{% endblock %}
{% block description %}Cool Places in Duisburg: Orte, Fotos, Infos und Feedbacks für ausgewählte Highlights der Stadt.{% endblock %}

{% block body %}
    <div class="places-page">
        <header class="site-header">
            <div class="nav-inner" aria-label="Hauptnavigation">
                <a class="brand" href="/" aria-label="Tripora">
                    <img
                        class="brand-logo"
                        src="/assets/logos/tripora_logo_v3_header.png"
                        alt="Tripora"
                        loading="eager"
                        decoding="async"
                    >
                </a>
                <nav class="main-nav" aria-label="Bereiche">
                    <a href="/einzelattraktion">Einzelattraktion</a>
                    <a href="/highlights-paket">Highlights-Paket</a>
                    <a href="/api/cities">API</a>
                </nav>
                <div class="nav-actions" aria-label="Schnellzugriff">
                    <a class="nav-action is-filled" href="#place-cards">Duisburg</a>
                    <a class="nav-action is-outline has-icon" href="/">
                        <span class="nav-login-icon" aria-hidden="true"></span>
                        <span>Anmelden</span>
                    </a>
                </div>
            </div>
        </header>

        <main class="has-fixed-header-offset">
            <section class="place-detail-hero" aria-labelledby="place-hero-title">
                <div class="place-detail-hero-content">
                    <div class="hero-label">
                        <span class="hero-kicker">City Guide</span>
                        <span class="hero-divider"></span>
                        <span class="hero-city">Duisburg</span>
                    </div>
                    <h1 id="place-hero-title">Entdecke die verborgenen <br>Seiten der Stadt.</h1>
                </div>
            </section>

            <div class="place-detail-container">
                <section class="place-selection">
                    <div class="selection-header">
                        <h2>Must-see Orte</h2>
                        <p>Wähle einen Ort aus, um Details zu sehen</p>
                    </div>
                    <div class="place-card-rail" data-place-cards></div>
                </section>

                <div class="place-main-content">
                    <div class="content-left">
                        <div id="place-gallery" class="place-gallery-section" data-place-carousel></div>
                    </div>
                    <div class="content-right">
                        <div class="place-info-section" data-place-info></div>
                    </div>
                </div>

                <section id="place-feedback" class="place-feedback-section" data-place-feedback></section>
            </div>
        </main>

        {% include 'partials/_footer.html.twig' %}
    </div>

    <script>window.COOL_PLACES_DATA = {{ coolPlacesJson|raw }};</script>
{% endblock %}
