{% extends 'base.html.twig' %}

{% block body %}
    <header class="site-header">
        <div class="nav-inner" aria-label="Hauptnavigation">
            <a class="brand" href="/" aria-label="Tripora">
                <span class="brand-spark" aria-hidden="true">T</span>
                <span class="brand-text">
                    <strong>TRIPORA</strong>
                    <small>City routes</small>
                </span>
            </a>
            <nav class="main-nav" aria-label="Bereiche">
                <a href="#places">Coole Städte</a>
                <a href="#cities">Reiseziele</a>
                <a href="#weekend">Wochenende</a>
                <a href="/api/cities">API</a>
            </nav>
            <div class="nav-actions" aria-label="Schnellzugriff">
                <a class="nav-action is-filled" href="#places">Inspiration</a>
                <a class="nav-action is-outline has-icon" href="#cities">
                    <span class="nav-login-icon" aria-hidden="true"></span>
                    <span>Anmelden</span>
                </a>
            </div>
        </div>
    </header>

    <main>
        <section class="hero" aria-labelledby="hero-title">
            <div class="hero-card">
                <div class="hero-shade" aria-hidden="true"></div>
                <div class="hero-content">
                    <span class="hero-kicker">Urlaub in Deutschland</span>
                    <h1 id="hero-title">Finde deine nächste Auszeit.</h1>
                    <form class="search-panel" data-city-search autocomplete="off">
                        <div class="search-fields">
                            <span class="country-mark" aria-hidden="true">
                                <span></span>
                                <span></span>
                                <span></span>
                            </span>
                            <label>
                                <span class="sr-only">Stadt suchen</span>
                                <input id="city-input" name="city" type="text" placeholder="z. B. Berlin" autocomplete="off" spellcheck="false" data-city-input role="combobox" aria-autocomplete="list" aria-controls="city-options" aria-expanded="false">
                            </label>
                            <span class="search-divider" aria-hidden="true"></span>
                            <button type="submit">
                                Suchen
                            </button>
                        </div>
                        <div class="city-options" id="city-options" data-city-options role="listbox" aria-label="Städte"></div>
                    </form>
                    <p>Städte voller Wasser, Licht, Märkte und kleiner Wege, die sich wie Urlaub anfühlen.</p>
                    <div class="hero-moods" aria-label="Reisestimmungen">
                        <span>Sonnenuntergang</span>
                        <span>Altstadt</span>
                        <span>Wochenende</span>
                    </div>

                </div>
            </div>
        </section>

        <section class="feed-shell">
            <section class="city-strip" id="cities" aria-label="Wichtigste Städte" data-city-strip></section>

            <section class="results-shell" id="places" aria-live="polite">
                <div class="section-heading">
                    <h2 data-results-heading>Neue Orte</h2>
                    <p data-results-copy>Entdecke eine kuratierte Auswahl an Orten zum Besuchen, Essen und Erleben.</p>
                </div>
                <div data-city-result></div>
            </section>
        </section>
    </main>

    <footer class="site-footer" id="weekend">
        <span>Tripora</span>
        <span>Kuratierte City Guides und Wochenendrouten, bereit für neue Länder.</span>
    </footer>

    <script>window.CITY_GUIDE_DATA = {{ citiesJson|raw }};</script>
{% endblock %}
