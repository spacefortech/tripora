{% extends 'base.html.twig' %}

{% block title %}Tripora - Erlebnisse, Ausflüge und City Guides{% endblock %}
{% block description %}Finde kuratierte City Guides, Ausflüge und Reiseideen für inspirierende Wochenenden in Deutschland.{% endblock %}

{% block body %}
    <div class="home-page">
        <header class="site-header home-header">
            <div class="nav-inner" aria-label="Hauptnavigation">
                <a class="brand" href="/" aria-label="Tripora">
                    <img
                        class="brand-logo"
                        src="/assets/logos/tripora_logo_v3_header.png"
                        alt="Tripora"
                        loading="eager"
                        decoding="async"
                    >
                </a>
                <nav class="main-nav" aria-label="Bereiche">
                    <a href="#places">Jetzt angesagt</a>
                    <a href="#inspire">Inspiration</a>
                    <a href="/cool-places">Cool Places</a>
                    <a href="/api/cities">API</a>
                </nav>
                <div class="nav-actions" aria-label="Schnellzugriff">
                    <a class="nav-action is-outline has-icon" href="#support">
                        <span class="nav-login-icon" aria-hidden="true"></span>
                        <span>Anmelden</span>
                    </a>
                </div>
            </div>
        </header>

        <main>
            <section class="hero home-hero" aria-labelledby="hero-title">
                <div class="hero-card">
                    <div class="hero-content">
                       {#  <span class="hero-kicker">Finde deine nächste Erfahrung</span> #}
                        <h1 id="hero-title">Erlebnisse, Ausflüge und City Guides</h1>
{#                        <p>Buche deinen nächsten Städtetrip mit kuratierten Orten, Routen und lokalen Highlights.</p>#}

                        <form class="search-panel home-search-panel" data-city-search autocomplete="off">
                            <div class="search-panel-title">Finde dein nächstes Erlebnis</div>
                            <div class="search-fields">
                                <span class="country-mark" aria-hidden="true">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </span>
                                <label>
                                    <span class="sr-only">Stadt suchen</span>
                                    <input id="city-input" name="city" type="text" placeholder="Stadt oder Erlebnis suchen" autocomplete="off" spellcheck="false" data-city-input role="combobox" aria-autocomplete="list" aria-controls="city-options" aria-expanded="false">
                                </label>
                                <span class="search-divider" aria-hidden="true"></span>
                                <span class="search-mode">City Guide</span>
                                <button type="submit">Suchen</button>
                            </div>
                            <div class="city-options" id="city-options" data-city-options role="listbox" aria-label="Städte"></div>
                        </form>

{#                        <div class="hero-trust" aria-label="Vorteile">
                            <div class="trust-item is-cancel">Kostenlose Stornierung</div>
                            <div class="trust-item is-instant">Sofortbestätigung</div>
                            <div class="trust-item is-green">Green &amp; Fair</div>
                        </div>#}
                    </div>
                </div>
            </section>

            <section class="feed-shell" id="support" aria-label="Service">
                <div class="section-heading is-left" aria-label="Urlaubsregionen entdecken">
                    <h2 id="cities-title">Urlaubsregionen entdecken</h2>
                    <p>Beliebte Städte, Regionen und Inspiration für deinen nächsten Kurztrip.</p>
                </div>
                <section class="city-strip" id="cities" aria-label="Wichtigste Städte" data-city-strip></section>

                <section class="results-shell" id="places" aria-live="polite">
                    <div class="section-heading">
                        <h2 data-results-heading>Jetzt angesagt</h2>
                        <p data-results-copy>Beliebte City-Erlebnisse mit klaren Routen, starken Motiven und genug Inspiration für dein nächstes Wochenende.</p>
                    </div>
                    <div data-city-result></div>
                </section>
            </section>

            <section class="reviews-section" id="inspire" aria-labelledby="reviews-title">
                <div class="section-heading">
                    <h2 id="reviews-title">Das sagen Reisende</h2>
                    <p>Echte Stimmen, echte Ideen – wisch dich durch die Highlights.</p>
                </div>

                <div class="reviews-shell" aria-label="Rezensionen (horizontal scroll)">
                    <button class="reviews-nav is-prev" type="button" data-reviews-prev aria-label="Vorherige Rezensionen">
                        <span aria-hidden="true">‹</span>
                    </button>

                    <div class="reviews-carousel" data-reviews-carousel tabindex="0" role="list">
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">M</span>
                                <div class="review-meta">
                                    <strong>Mara</strong>
                                    <span>Berlin · 5,0/5</span>
                                </div>
                            </div>
                            <p>„Super schnell eine Route gefunden. Die Tipps waren konkret und nicht dieses generische ‚Top 10‘-Zeug.“</p>
                        </article>
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">L</span>
                                <div class="review-meta">
                                    <strong>Luca</strong>
                                    <span>Köln · 4,8/5</span>
                                </div>
                            </div>
                            <p>„Ich hab direkt Spots gespeichert und am Wochenende abgeklappert. Genau die Mischung aus ‚nice‘ und machbar.“</p>
                        </article>
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">S</span>
                                <div class="review-meta">
                                    <strong>Sofia</strong>
                                    <span>Hamburg · 4,9/5</span>
                                </div>
                            </div>
                            <p>„Die Beschreibungen treffen den Vibe. Hat uns geholfen, ohne Stress einen schönen Tag zu planen.“</p>
                        </article>
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">T</span>
                                <div class="review-meta">
                                    <strong>Toni</strong>
                                    <span>München · 4,7/5</span>
                                </div>
                            </div>
                            <p>„Gute Auswahl, schöne Fotos, klare Infos. Vor allem die kurzen ‚warum lohnt es sich‘-Sätze sind gold.“</p>
                        </article>
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">N</span>
                                <div class="review-meta">
                                    <strong>Nora</strong>
                                    <span>Leipzig · 5,0/5</span>
                                </div>
                            </div>
                            <p>„Wir wollten spontan los – hier war nach 3 Minuten klar, wohin. Genau mein Tool für Kurztrips.“</p>
                        </article>
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">J</span>
                                <div class="review-meta">
                                    <strong>Jonas</strong>
                                    <span>Düsseldorf · 4,8/5</span>
                                </div>
                            </div>
                            <p>„Die Empfehlungen fühlen sich kuratiert an. Kein Overload, sondern ‚genug, um zu starten‘.“</p>
                        </article>
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">A</span>
                                <div class="review-meta">
                                    <strong>Alina</strong>
                                    <span>Frankfurt · 4,9/5</span>
                                </div>
                            </div>
                            <p>„Mega für Ideen nach Feierabend: ein Spot, ein Kaffee, fertig. Genau das, was mir oft fehlt.“</p>
                        </article>
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">B</span>
                                <div class="review-meta">
                                    <strong>Ben</strong>
                                    <span>Stuttgart · 4,7/5</span>
                                </div>
                            </div>
                            <p>„Schönes Layout, schnelle Orientierung. Ich mag, dass man sofort sieht, was sich wirklich lohnt.“</p>
                        </article>
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">E</span>
                                <div class="review-meta">
                                    <strong>Elena</strong>
                                    <span>Bremen · 5,0/5</span>
                                </div>
                            </div>
                            <p>„Wir haben zwei Vorschläge kombiniert und hatten einen perfekten Tag – ohne endlos zu googeln.“</p>
                        </article>
                        <article class="review-card" role="listitem">
                            <div class="review-top">
                                <span class="review-avatar" aria-hidden="true">P</span>
                                <div class="review-meta">
                                    <strong>Paolo</strong>
                                    <span>Nürnberg · 4,8/5</span>
                                </div>
                            </div>
                            <p>„Die Tipps sind echt praktisch. Man merkt, dass hier jemand kuratiert statt einfach zu sammeln.“</p>
                        </article>
                    </div>

                    <button class="reviews-nav is-next" type="button" data-reviews-next aria-label="Nächste Rezensionen">
                        <span aria-hidden="true">›</span>
                    </button>
                </div>
            </section>
        </main>

        <footer class="site-footer" aria-label="Footer">
            <div class="footer-inner">
                <div class="footer-columns" aria-label="Footer Links">
                    <div class="footer-col">
                        <h3 class="footer-title">Unternehmen</h3>
                        <a class="footer-link" href="#">Über uns</a>
                        <a class="footer-link" href="#support">Kontakt</a>
                        <a class="footer-link" href="#">Kooperation</a>
                        <a class="footer-link" href="#">Presse</a>
                        <a class="footer-link" href="#">Karriere</a>
                    </div>
                    <div class="footer-col">
                        <h3 class="footer-title">Info</h3>
                        <a class="footer-link" href="#cities">Übersicht City Guides</a>
                        <a class="footer-link" href="#places">Reisethemen</a>
                        <a class="footer-link" href="#">Schlagworte</a>
                        <a class="footer-link" href="#">Fakten</a>
                        <a class="footer-link" href="#">FAQ</a>
                    </div>
                    <div class="footer-col">
                        <h3 class="footer-title">Länder</h3>
                        <a class="footer-link" href="#"><span aria-hidden="true">🇩🇪</span> tripora.de</a>
                        <a class="footer-link" href="#"><span aria-hidden="true">🇦🇹</span> tripora.at</a>
                    </div>
                </div>

                <div class="footer-bottom" aria-label="Rechtliches">
                    <nav class="footer-legal" aria-label="Links">
                        <a class="footer-legal-link" href="#">Cookies</a>
                        <span class="footer-sep" aria-hidden="true">|</span>
                        <a class="footer-legal-link" href="#">Datenschutz</a>
                        <span class="footer-sep" aria-hidden="true">|</span>
                        <a class="footer-legal-link" href="#">Impressum</a>
                        <span class="footer-sep" aria-hidden="true">|</span>
                        <a class="footer-legal-link" href="#">Barrierefreiheit</a>
                    </nav>
                    <div class="footer-copy">© 2013 - 2026 Tripora · City Guides &amp; Kurztrip-Ideen</div>
                </div>
            </div>
        </footer>
    </div>

    <script>window.CITY_GUIDE_DATA = {{ citiesJson|raw }};</script>
{% endblock %}
